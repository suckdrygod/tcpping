@@ -0,0 +1,98 @@
+package server
+
+import (
+	"os"
+	"testing"
+)
+
+func TestSelectVnstatInterfaceUsesLargestTotal(t *testing.T) {
+	procNetRoutePath = t.TempDir() + "/missing"
+	t.Cleanup(func() { procNetRoutePath = "/proc/net/route" })
+
+	iface, ok := selectVnstatInterface([]vnstatInterface{
+		{
+			Name: "eth0",
+			Traffic: vnstatTraffic{
+				Total: vnstatCounter{Rx: 100, Tx: 50},
+			},
+		},
+		{
+			Name: "ens3",
+			Traffic: vnstatTraffic{
+				Total: vnstatCounter{Rx: 200, Tx: 300},
+			},
+		},
+	})
+
+	if !ok {
+		t.Fatal("expected an interface to be selected")
+	}
+	if iface.Name != "ens3" {
+		t.Fatalf("expected ens3, got %s", iface.Name)
+	}
+}
+
+func TestSelectVnstatInterfaceHandlesEmptyList(t *testing.T) {
+	if _, ok := selectVnstatInterface(nil); ok {
+		t.Fatal("expected no interface to be selected")
+	}
+}
+
+func TestSelectVnstatInterfacePrefersDefaultRoute(t *testing.T) {
+	routeFile := t.TempDir() + "/route"
+	err := os.WriteFile(routeFile, []byte("Iface\tDestination\tGateway\tFlags\neth0\t00000000\t01020304\t0003\n"), 0o600)
+	if err != nil {
+		t.Fatal(err)
+	}
+	procNetRoutePath = routeFile
+	t.Cleanup(func() { procNetRoutePath = "/proc/net/route" })
+
+	iface, ok := selectVnstatInterface([]vnstatInterface{
+		{
+			Name: "br-1234",
+			Traffic: vnstatTraffic{
+				Total: vnstatCounter{Rx: 1000, Tx: 1000},
+			},
+		},
+		{
+			Name: "eth0",
+			Traffic: vnstatTraffic{
+				Total: vnstatCounter{Rx: 1, Tx: 1},
+			},
+		},
+	})
+
+	if !ok {
+		t.Fatal("expected an interface to be selected")
+	}
+	if iface.Name != "eth0" {
+		t.Fatalf("expected eth0, got %s", iface.Name)
+	}
+}
+
+func TestSelectVnstatInterfaceSkipsVirtualWhenNoDefaultRoute(t *testing.T) {
+	procNetRoutePath = t.TempDir() + "/missing"
+	t.Cleanup(func() { procNetRoutePath = "/proc/net/route" })
+
+	iface, ok := selectVnstatInterface([]vnstatInterface{
+		{
+			Name: "br-1234",
+			Traffic: vnstatTraffic{
+				Total: vnstatCounter{Rx: 1000, Tx: 1000},
+			},
+		},
+		{
+			Name: "eth0",
+			Traffic: vnstatTraffic{
+				Total: vnstatCounter{Rx: 1, Tx: 1},
+			},
+		},
+	})
+
+	if !ok {
+		t.Fatal("expected an interface to be selected")
+	}
+	if iface.Name != "eth0" {
+		t.Fatalf("expected eth0, got %s", iface.Name)
+	}
+}
