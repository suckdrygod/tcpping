diff --git a/server/safe_tcp_ping.go b/server/safe_tcp_ping.go
new file mode 100644
index 0000000..13860ee
--- /dev/null
+++ b/server/safe_tcp_ping.go
@@ -0,0 +1,255 @@
+package server
+
+import (
+	"bytes"
+	"encoding/json"
+	"errors"
+	"fmt"
+	"io"
+	"log"
+	"net"
+	"net/http"
+	"strconv"
+	"strings"
+	"sync"
+	"time"
+
+	"github.com/komari-monitor/komari-agent/dnsresolver"
+	v2 "github.com/komari-monitor/komari-agent/protocol/v2"
+	"github.com/komari-monitor/komari-agent/ws"
+)
+
+// Safe TCP policy:
+//   * only the "tcp" ping type is implemented;
+//   * an explicit host:port is required;
+//   * host and port must be allow-listed;
+//   * DNS answers are pinned and private/local/reserved addresses are rejected;
+//   * a sliding-window limit prevents the agent being used for high-rate scanning.
+// There is deliberately no ICMP, HTTP, terminal, exec, file-transfer, or shell path.
+
+var safeTCPTaskWindow struct {
+	sync.Mutex
+	accepted []time.Time
+}
+
+func NewSafeTCPPingTask(conn *ws.SafeConn, protocolVersion int, taskID uint, pingType, pingTarget string) {
+	if taskID == 0 {
+		log.Printf("ignored TCP probe without task id")
+		return
+	}
+
+	result := -1
+	if strings.EqualFold(strings.TrimSpace(pingType), "tcp") {
+		if !allowSafeTCPTask() {
+			log.Printf("TCP probe task %d rejected: rate limit", taskID)
+		} else if latency, err := measureSafeTCP(pingTarget); err != nil {
+			log.Printf("TCP probe task %d rejected/failed: %v", taskID, err)
+		} else {
+			result = int(latency.Milliseconds())
+		}
+	} else {
+		log.Printf("TCP probe task %d rejected: ping type %q is not allowed", taskID, pingType)
+	}
+
+	finishedAt := time.Now().UTC()
+	if protocolVersion >= 2 {
+		payload := v2.BuildPingResultPayload(taskID, "tcp", result, finishedAt)
+		if conn != nil {
+			if err := conn.WriteJSON(payload); err != nil {
+				log.Printf("failed to send TCP probe result over WebSocket: %v", err)
+			}
+			return
+		}
+		if err := postSafeTCPPingResult(payload); err != nil {
+			log.Printf("failed to POST TCP probe result: %v", err)
+		}
+		return
+	}
+
+	// v1 supports result delivery only while its report WebSocket is connected.
+	if conn == nil {
+		log.Printf("dropping v1 TCP probe result: no active WebSocket")
+		return
+	}
+	payload := map[string]interface{}{
+		"type":        "ping_result",
+		"task_id":     taskID,
+		"ping_type":   "tcp",
+		"value":       result,
+		"finished_at": finishedAt.Format(time.RFC3339Nano),
+	}
+	if err := conn.WriteJSON(payload); err != nil {
+		log.Printf("failed to send v1 TCP probe result: %v", err)
+	}
+}
+
+func allowSafeTCPTask() bool {
+	now := time.Now()
+	limit := flags.SafeTCPMaxTasksPerMinute
+	if limit < 1 {
+		limit = 30
+	}
+
+	safeTCPTaskWindow.Lock()
+	defer safeTCPTaskWindow.Unlock()
+	cutoff := now.Add(-time.Minute)
+	kept := safeTCPTaskWindow.accepted[:0]
+	for _, t := range safeTCPTaskWindow.accepted {
+		if t.After(cutoff) {
+			kept = append(kept, t)
+		}
+	}
+	safeTCPTaskWindow.accepted = kept
+	if len(safeTCPTaskWindow.accepted) >= limit {
+		return false
+	}
+	safeTCPTaskWindow.accepted = append(safeTCPTaskWindow.accepted, now)
+	return true
+}
+
+func measureSafeTCP(target string) (time.Duration, error) {
+	host, portText, err := net.SplitHostPort(strings.TrimSpace(target))
+	if err != nil {
+		return 0, errors.New("target must be an explicit host:port")
+	}
+	host = strings.TrimSuffix(strings.Trim(strings.TrimSpace(host), "[]"), ".")
+	if host == "" {
+		return 0, errors.New("empty target host")
+	}
+	port, err := strconv.Atoi(portText)
+	if err != nil || port < 1 || port > 65535 {
+		return 0, errors.New("invalid target port")
+	}
+	if !safeTCPHostAllowed(host) {
+		return 0, fmt.Errorf("host %q is not on the TCP probe allow-list", host)
+	}
+	if !safeTCPPortAllowed(port) {
+		return 0, fmt.Errorf("port %d is not on the TCP probe allow-list", port)
+	}
+
+	ips, err := net.LookupIP(host)
+	if err != nil || len(ips) == 0 {
+		return 0, errors.New("unable to resolve target host")
+	}
+	for _, ip := range ips {
+		if !safeTCPPublicIP(ip) {
+			return 0, fmt.Errorf("target resolves to a forbidden address: %s", ip)
+		}
+	}
+
+	timeout := time.Duration(flags.SafeTCPTimeoutSeconds) * time.Second
+	if timeout < time.Second {
+		timeout = 3 * time.Second
+	}
+	if timeout > 10*time.Second {
+		timeout = 10 * time.Second
+	}
+
+	// Pin the validated IP address. Do not dial the hostname after validation,
+	// otherwise a later DNS answer could turn the task into an internal probe.
+	address := net.JoinHostPort(ips[0].String(), strconv.Itoa(port))
+	start := time.Now()
+	conn, err := net.DialTimeout("tcp", address, timeout)
+	if err != nil {
+		return 0, err
+	}
+	_ = conn.Close()
+	return time.Since(start), nil
+}
+
+func safeTCPHostAllowed(host string) bool {
+	normalized := strings.ToLower(strings.TrimSuffix(strings.TrimSpace(host), "."))
+	for _, raw := range strings.Split(flags.SafeTCPAllowHosts, ",") {
+		rule := strings.ToLower(strings.TrimSuffix(strings.TrimSpace(raw), "."))
+		if rule == "" {
+			continue
+		}
+		if strings.HasPrefix(rule, "*.") {
+			suffix := strings.TrimPrefix(rule, "*") // keep leading dot
+			if strings.HasSuffix(normalized, suffix) && normalized != strings.TrimPrefix(suffix, ".") {
+				return true
+			}
+			continue
+		}
+		if normalized == rule {
+			return true
+		}
+	}
+	return false
+}
+
+func safeTCPPortAllowed(port int) bool {
+	for _, raw := range strings.Split(flags.SafeTCPAllowPorts, ",") {
+		value, err := strconv.Atoi(strings.TrimSpace(raw))
+		if err == nil && value == port {
+			return true
+		}
+	}
+	return false
+}
+
+func safeTCPPublicIP(ip net.IP) bool {
+	if ip == nil || ip.IsUnspecified() || ip.IsLoopback() || ip.IsPrivate() ||
+		ip.IsLinkLocalUnicast() || ip.IsLinkLocalMulticast() || ip.IsMulticast() {
+		return false
+	}
+	if v4 := ip.To4(); v4 != nil {
+		switch {
+		case v4[0] == 0: // "this" network
+			return false
+		case v4[0] == 100 && v4[1] >= 64 && v4[1] <= 127: // CGNAT
+			return false
+		case v4[0] == 192 && v4[1] == 0: // IETF protocol assignments
+			return false
+		case v4[0] == 192 && v4[1] == 0 && v4[2] == 2: // TEST-NET-1 (covered above)
+			return false
+		case v4[0] == 198 && (v4[1] == 18 || v4[1] == 19): // benchmarking
+			return false
+		case v4[0] == 198 && v4[1] == 51 && v4[2] == 100: // TEST-NET-2
+			return false
+		case v4[0] == 203 && v4[1] == 0 && v4[2] == 113: // TEST-NET-3
+			return false
+		case v4[0] >= 224: // multicast, reserved, and limited broadcast
+			return false
+		}
+	}
+	return true
+}
+
+func postSafeTCPPingResult(payload interface{}) error {
+	body, err := json.Marshal(payload)
+	if err != nil {
+		return err
+	}
+	compressed := false
+	if !flags.DisableCompression {
+		if gz, err := gzipBytes(body); err == nil {
+			body = gz
+			compressed = true
+		}
+	}
+	endpoint := strings.TrimSuffix(flags.Endpoint, "/") + "/api/clients/v2/rpc?token=" + flags.Token
+	req, err := http.NewRequest(http.MethodPost, endpoint, bytes.NewReader(body))
+	if err != nil {
+		return err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	if compressed {
+		req.Header.Set("Content-Encoding", "gzip")
+	}
+	if flags.CFAccessClientID != "" && flags.CFAccessClientSecret != "" {
+		req.Header.Set("CF-Access-Client-Id", flags.CFAccessClientID)
+		req.Header.Set("CF-Access-Client-Secret", flags.CFAccessClientSecret)
+	}
+	client := dnsresolver.GetHTTPClientWithPreference(30*time.Second, flags.PreferIPVersion)
+	resp, err := client.Do(req)
+	if err != nil {
+		return err
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode != http.StatusOK {
+		data, _ := io.ReadAll(io.LimitReader(resp.Body, 2048))
+		return fmt.Errorf("status %s: %s", resp.Status, strings.TrimSpace(string(data)))
+	}
+	return nil
+}
diff --git a/server/ssh_auth_guard.go b/server/ssh_auth_guard.go
new file mode 100644
index 0000000..4f09e90
--- /dev/null
+++ b/server/ssh_auth_guard.go
@@ -0,0 +1,382 @@
+package server
+
+import (
+	"bufio"
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"log"
+	"net"
+	"net/http"
+	"os"
+	"os/exec"
+	"regexp"
+	"strings"
+	"time"
+	"unicode"
+
+	"github.com/komari-monitor/komari-agent/dnsresolver"
+)
+
+var (
+	failedPasswordPattern  = regexp.MustCompile(`Failed password for (?:invalid user )?([^ ]+) from ([0-9A-Fa-f:.]+)`)
+	invalidUserPattern     = regexp.MustCompile(`Invalid user ([^ ]+) from ([0-9A-Fa-f:.]+)`)
+	failedPublicKeyPattern = regexp.MustCompile(`Failed publickey for (?:invalid user )?([^ ]+) from ([0-9A-Fa-f:.]+)`)
+	pamFailureRhostPattern = regexp.MustCompile(`\brhost=([0-9A-Fa-f:.]+)`)
+	pamFailureUserPattern  = regexp.MustCompile(`\buser=([^ ]+)`)
+)
+
+type sshAuthFailure struct {
+	sourceIP      string
+	user          string
+	method        string
+	occurredAt    time.Time
+	sampleMessage string
+}
+
+type sshAuthGuardAlert struct {
+	sourceIP      string
+	user          string
+	method        string
+	failedCount   int
+	windowSeconds int
+	occurredAt    time.Time
+	sampleMessage string
+}
+
+type sshAuthGuard struct {
+	threshold int
+	window    time.Duration
+	cooldown  time.Duration
+	rootOnly  bool
+	report    func(sshAuthGuardAlert) error
+	now       func() time.Time
+	buckets   map[string][]sshAuthFailure
+	lastAlert map[string]time.Time
+}
+
+// StartSSHAuthGuard is a read-only, alert-only SSH authentication failure
+// monitor. It does not modify PAM, sshd, firewall rules, or any other system
+// configuration.
+func StartSSHAuthGuard(ctx context.Context) {
+	guard := newSSHAuthGuardFromFlags()
+	if _, err := exec.LookPath("journalctl"); err == nil {
+		go watchSSHAuthGuardJournal(ctx, guard)
+		return
+	}
+	log.Printf("SSH auth guard journal fallback unavailable: journalctl not found")
+	watchSSHAuthGuardFiles(ctx, guard)
+}
+
+func newSSHAuthGuardFromFlags() *sshAuthGuard {
+	threshold := flags.SSHAuthThreshold
+	if threshold == 0 {
+		threshold = 5
+	}
+	windowSeconds := flags.SSHAuthWindowSeconds
+	if windowSeconds == 0 {
+		windowSeconds = 60
+	}
+	cooldownSeconds := flags.SSHAuthCooldownSeconds
+	if cooldownSeconds == 0 {
+		cooldownSeconds = 600
+	}
+	return newSSHAuthGuard(threshold, time.Duration(windowSeconds)*time.Second, time.Duration(cooldownSeconds)*time.Second, flags.SSHAuthRootOnly, reportSSHAuthGuardAlert)
+}
+
+func newSSHAuthGuard(threshold int, window, cooldown time.Duration, rootOnly bool, report func(sshAuthGuardAlert) error) *sshAuthGuard {
+	if threshold <= 0 {
+		threshold = 5
+	}
+	if window <= 0 {
+		window = time.Minute
+	}
+	if cooldown <= 0 {
+		cooldown = 10 * time.Minute
+	}
+	if report == nil {
+		report = func(sshAuthGuardAlert) error { return nil }
+	}
+	return &sshAuthGuard{
+		threshold: threshold,
+		window:    window,
+		cooldown:  cooldown,
+		rootOnly:  rootOnly,
+		report:    report,
+		now:       time.Now,
+		buckets:   make(map[string][]sshAuthFailure),
+		lastAlert: make(map[string]time.Time),
+	}
+}
+
+func watchSSHAuthGuardJournal(ctx context.Context, guard *sshAuthGuard) {
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		default:
+		}
+		if err := runSSHAuthGuardJournal(ctx, guard); err != nil && ctx.Err() == nil {
+			log.Printf("SSH auth guard journal watcher stopped: %v", err)
+			select {
+			case <-ctx.Done():
+				return
+			case <-time.After(10 * time.Second):
+			}
+		}
+	}
+}
+
+func runSSHAuthGuardJournal(ctx context.Context, guard *sshAuthGuard) error {
+	cmd := exec.CommandContext(ctx, "journalctl", "-u", "ssh", "-u", "sshd", "-f", "-o", "short-iso")
+	stdout, err := cmd.StdoutPipe()
+	if err != nil {
+		return err
+	}
+	cmd.Stderr = io.Discard
+	if err := cmd.Start(); err != nil {
+		return err
+	}
+	log.Printf("SSH auth guard watching systemd journal")
+	err = scanSSHAuthGuardLines(stdout, guard)
+	waitErr := cmd.Wait()
+	if err != nil {
+		return err
+	}
+	return waitErr
+}
+
+func watchSSHAuthGuardFiles(ctx context.Context, guard *sshAuthGuard) {
+	paths := []string{"/var/log/auth.log", "/var/log/secure"}
+	states := make(map[string]*sshLogState, len(paths))
+	for _, path := range paths {
+		if state := openSSHLogAtEnd(path); state != nil {
+			states[path] = state
+			log.Printf("SSH auth guard watching %s", path)
+		}
+	}
+	if len(states) == 0 {
+		log.Printf("SSH auth guard waiting for /var/log/auth.log or /var/log/secure")
+	}
+
+	ticker := time.NewTicker(2 * time.Second)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case <-ticker.C:
+			for _, path := range paths {
+				state := states[path]
+				if state == nil {
+					if next := openSSHLogAtEnd(path); next != nil {
+						states[path] = next
+						log.Printf("SSH auth guard watching %s", path)
+					}
+					continue
+				}
+				if err := pollSSHAuthGuardFile(state, guard); err != nil && !os.IsNotExist(err) {
+					log.Printf("SSH auth guard failed to read %s: %v", path, err)
+				}
+			}
+		}
+	}
+}
+
+func pollSSHAuthGuardFile(state *sshLogState, guard *sshAuthGuard) error {
+	info, err := os.Stat(state.path)
+	if err != nil {
+		return err
+	}
+	if !os.SameFile(state.info, info) || info.Size() < state.offset {
+		state.offset = 0
+		state.info = info
+	}
+	if info.Size() == state.offset {
+		return nil
+	}
+
+	file, err := os.Open(state.path)
+	if err != nil {
+		return err
+	}
+	defer file.Close()
+	if _, err := file.Seek(state.offset, io.SeekStart); err != nil {
+		return err
+	}
+	if err := scanSSHAuthGuardLines(file, guard); err != nil {
+		return err
+	}
+	state.offset, err = file.Seek(0, io.SeekCurrent)
+	return err
+}
+
+func scanSSHAuthGuardLines(reader io.Reader, guard *sshAuthGuard) error {
+	scanner := bufio.NewScanner(reader)
+	scanner.Buffer(make([]byte, 4096), 64*1024)
+	for scanner.Scan() {
+		if failure, ok := parseSSHAuthFailure(scanner.Text(), guard.now()); ok {
+			guard.Observe(failure)
+		}
+	}
+	return scanner.Err()
+}
+
+func parseSSHAuthFailure(line string, now time.Time) (sshAuthFailure, bool) {
+	for _, parser := range []struct {
+		method  string
+		pattern *regexp.Regexp
+	}{
+		{method: "password", pattern: failedPasswordPattern},
+		{method: "invalid-user", pattern: invalidUserPattern},
+		{method: "publickey", pattern: failedPublicKeyPattern},
+	} {
+		match := parser.pattern.FindStringSubmatch(line)
+		if len(match) == 3 && net.ParseIP(match[2]) != nil {
+			return sshAuthFailure{
+				sourceIP:      match[2],
+				user:          sanitizeSSHAuthGuardToken(match[1], "unknown"),
+				method:        parser.method,
+				occurredAt:    now.UTC(),
+				sampleMessage: sanitizeSSHAuthGuardSample(line),
+			}, true
+		}
+	}
+
+	if strings.Contains(line, "pam_unix(sshd:auth): authentication failure") {
+		ipMatch := pamFailureRhostPattern.FindStringSubmatch(line)
+		if len(ipMatch) != 2 || net.ParseIP(ipMatch[1]) == nil {
+			return sshAuthFailure{}, false
+		}
+		user := "unknown"
+		if userMatch := pamFailureUserPattern.FindStringSubmatch(line); len(userMatch) == 2 {
+			user = sanitizeSSHAuthGuardToken(userMatch[1], "unknown")
+		}
+		return sshAuthFailure{
+			sourceIP:      ipMatch[1],
+			user:          user,
+			method:        "pam",
+			occurredAt:    now.UTC(),
+			sampleMessage: sanitizeSSHAuthGuardSample(line),
+		}, true
+	}
+	return sshAuthFailure{}, false
+}
+
+func (g *sshAuthGuard) Observe(failure sshAuthFailure) {
+	if g.rootOnly && failure.user != "root" {
+		return
+	}
+	key := failure.sourceIP + "|" + failure.user
+	cutoff := failure.occurredAt.Add(-g.window)
+	bucket := g.buckets[key][:0]
+	for _, item := range g.buckets[key] {
+		if !item.occurredAt.Before(cutoff) {
+			bucket = append(bucket, item)
+		}
+	}
+	bucket = append(bucket, failure)
+	g.buckets[key] = bucket
+
+	if len(bucket) < g.threshold {
+		return
+	}
+	if last, ok := g.lastAlert[key]; ok && failure.occurredAt.Sub(last) < g.cooldown {
+		return
+	}
+	g.lastAlert[key] = failure.occurredAt
+	if err := g.report(sshAuthGuardAlert{
+		sourceIP:      failure.sourceIP,
+		user:          failure.user,
+		method:        failure.method,
+		failedCount:   len(bucket),
+		windowSeconds: int(g.window / time.Second),
+		occurredAt:    failure.occurredAt,
+		sampleMessage: failure.sampleMessage,
+	}); err != nil {
+		log.Printf("failed to report SSH auth guard alert: %v", err)
+	}
+}
+
+func reportSSHAuthGuardAlert(alert sshAuthGuardAlert) error {
+	payload, err := json.Marshal(map[string]interface{}{
+		"source_ip":      alert.sourceIP,
+		"user":           alert.user,
+		"method":         alert.method,
+		"failed_count":   alert.failedCount,
+		"window_seconds": alert.windowSeconds,
+		"occurred_at":    alert.occurredAt.Format(time.RFC3339Nano),
+		"sample_message": alert.sampleMessage,
+	})
+	if err != nil {
+		return err
+	}
+	endpoint := strings.TrimSuffix(flags.Endpoint, "/") + "/api/clients/ssh-auth-guard?token=" + flags.Token
+	req, err := http.NewRequest(http.MethodPost, endpoint, bytes.NewReader(payload))
+	if err != nil {
+		return err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	if flags.CFAccessClientID != "" && flags.CFAccessClientSecret != "" {
+		req.Header.Set("CF-Access-Client-Id", flags.CFAccessClientID)
+		req.Header.Set("CF-Access-Client-Secret", flags.CFAccessClientSecret)
+	}
+	client := dnsresolver.GetHTTPClientWithPreference(15*time.Second, flags.PreferIPVersion)
+	resp, err := client.Do(req)
+	if err != nil {
+		return err
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode < http.StatusOK || resp.StatusCode >= http.StatusMultipleChoices {
+		data, _ := io.ReadAll(io.LimitReader(resp.Body, 1024))
+		return fmt.Errorf("status %s: %s", resp.Status, strings.TrimSpace(string(data)))
+	}
+	return nil
+}
+
+func sanitizeSSHAuthGuardToken(value, fallback string) string {
+	value = strings.TrimSpace(value)
+	if value == "" {
+		return fallback
+	}
+	var b strings.Builder
+	for _, r := range value {
+		if r == '.' || r == '_' || r == '-' || ('0' <= r && r <= '9') || ('A' <= r && r <= 'Z') || ('a' <= r && r <= 'z') {
+			b.WriteRune(r)
+		} else {
+			b.WriteByte('_')
+		}
+		if b.Len() >= 64 {
+			break
+		}
+	}
+	result := strings.Trim(b.String(), "_")
+	if result == "" {
+		return fallback
+	}
+	return result
+}
+
+func sanitizeSSHAuthGuardSample(line string) string {
+	line = strings.TrimSpace(line)
+	if line == "" {
+		return ""
+	}
+	var b strings.Builder
+	for _, r := range line {
+		if r == '\n' || r == '\r' || r == '\t' {
+			b.WriteByte(' ')
+			continue
+		}
+		if unicode.IsControl(r) {
+			continue
+		}
+		b.WriteRune(r)
+		if b.Len() >= 240 {
+			break
+		}
+	}
+	return strings.TrimSpace(b.String())
+}
diff --git a/server/ssh_auth_guard_test.go b/server/ssh_auth_guard_test.go
new file mode 100644
index 0000000..6c864c4
--- /dev/null
+++ b/server/ssh_auth_guard_test.go
@@ -0,0 +1,80 @@
+package server
+
+import (
+	"testing"
+	"time"
+)
+
+func TestParseSSHAuthFailure(t *testing.T) {
+	now := time.Date(2026, 6, 23, 12, 0, 0, 0, time.UTC)
+	tests := []struct {
+		line   string
+		user   string
+		ip     string
+		method string
+	}{
+		{"Jun 23 12:00:00 host sshd[1]: Failed password for root from 203.0.113.5 port 22 ssh2", "root", "203.0.113.5", "password"},
+		{"2026-06-23T12:00:00 host sshd[2]: Failed password for invalid user admin from 2001:db8::10 port 22 ssh2", "admin", "2001:db8::10", "password"},
+		{"Invalid user test from 198.51.100.7 port 3322", "test", "198.51.100.7", "invalid-user"},
+		{"Failed publickey for ubuntu from 198.51.100.8 port 22 ssh2", "ubuntu", "198.51.100.8", "publickey"},
+		{"pam_unix(sshd:auth): authentication failure; rhost=203.0.113.9 user=root", "root", "203.0.113.9", "pam"},
+	}
+	for _, test := range tests {
+		failure, ok := parseSSHAuthFailure(test.line, now)
+		if !ok {
+			t.Fatalf("expected parse success for %q", test.line)
+		}
+		if failure.user != test.user || failure.sourceIP != test.ip || failure.method != test.method {
+			t.Fatalf("unexpected parse result: %#v", failure)
+		}
+	}
+}
+
+func TestSSHAuthGuardThresholdAndCooldown(t *testing.T) {
+	var alerts []sshAuthGuardAlert
+	guard := newSSHAuthGuard(5, time.Minute, 10*time.Minute, false, func(alert sshAuthGuardAlert) error {
+		alerts = append(alerts, alert)
+		return nil
+	})
+	base := time.Date(2026, 6, 23, 12, 0, 0, 0, time.UTC)
+	for i := 0; i < 5; i++ {
+		guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base.Add(time.Duration(i) * time.Second)})
+	}
+	if len(alerts) != 1 {
+		t.Fatalf("expected one alert, got %d", len(alerts))
+	}
+	if alerts[0].failedCount != 5 || alerts[0].windowSeconds != 60 {
+		t.Fatalf("unexpected alert: %#v", alerts[0])
+	}
+	for i := 0; i < 5; i++ {
+		guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base.Add(time.Duration(30+i) * time.Second)})
+	}
+	if len(alerts) != 1 {
+		t.Fatalf("cooldown should suppress duplicate alert, got %d", len(alerts))
+	}
+	for i := 0; i < 5; i++ {
+		guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base.Add(11*time.Minute + time.Duration(i)*time.Second)})
+	}
+	if len(alerts) != 2 {
+		t.Fatalf("expected alert after cooldown, got %d", len(alerts))
+	}
+}
+
+func TestSSHAuthGuardRootOnly(t *testing.T) {
+	var alerts []sshAuthGuardAlert
+	guard := newSSHAuthGuard(2, time.Minute, 10*time.Minute, true, func(alert sshAuthGuardAlert) error {
+		alerts = append(alerts, alert)
+		return nil
+	})
+	base := time.Date(2026, 6, 23, 12, 0, 0, 0, time.UTC)
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "ubuntu", method: "password", occurredAt: base})
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "ubuntu", method: "password", occurredAt: base.Add(time.Second)})
+	if len(alerts) != 0 {
+		t.Fatalf("non-root failures should be ignored in root-only mode")
+	}
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base})
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base.Add(time.Second)})
+	if len(alerts) != 1 {
+		t.Fatalf("root failures should trigger alert, got %d", len(alerts))
+	}
+}
diff --git a/server/ssh_login_watch.go b/server/ssh_login_watch.go
new file mode 100644
index 0000000..7762427
--- /dev/null
+++ b/server/ssh_login_watch.go
@@ -0,0 +1,150 @@
+package server
+
+import (
+	"bufio"
+	"context"
+	"fmt"
+	"io"
+	"log"
+	"net"
+	"os"
+	"regexp"
+	"strconv"
+	"strings"
+	"time"
+
+	v2 "github.com/komari-monitor/komari-agent/protocol/v2"
+)
+
+var acceptedSSHLoginPattern = regexp.MustCompile(`sshd(?:\[[0-9]+\])?: Accepted ([^ ]+) for ([A-Za-z0-9._-]+) from ([0-9A-Fa-f:.]+) port ([0-9]+)`)
+
+type sshLogState struct {
+	path   string
+	offset int64
+	info   os.FileInfo
+}
+
+// StartSSHLoginWatcher tails only successful OpenSSH authentication records.
+// It never writes SSH configuration and never executes a command. Existing
+// log contents are skipped on startup so an agent restart cannot replay old
+// login events.
+func StartSSHLoginWatcher(ctx context.Context) {
+	paths := []string{"/var/log/auth.log", "/var/log/secure"}
+	states := make(map[string]*sshLogState, len(paths))
+	for _, path := range paths {
+		if state := openSSHLogAtEnd(path); state != nil {
+			states[path] = state
+			log.Printf("SSH login notifier watching %s", path)
+		}
+	}
+	if len(states) == 0 {
+		log.Printf("SSH login notifier waiting for /var/log/auth.log or /var/log/secure")
+	}
+
+	ticker := time.NewTicker(2 * time.Second)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case <-ticker.C:
+			for _, path := range paths {
+				state := states[path]
+				if state == nil {
+					if next := openSSHLogAtEnd(path); next != nil {
+						states[path] = next
+						log.Printf("SSH login notifier watching %s", path)
+					}
+					continue
+				}
+				if err := pollSSHLog(state); err != nil && !os.IsNotExist(err) {
+					log.Printf("SSH login notifier failed to read %s: %v", path, err)
+				}
+			}
+		}
+	}
+}
+
+func openSSHLogAtEnd(path string) *sshLogState {
+	info, err := os.Stat(path)
+	if err != nil || !info.Mode().IsRegular() {
+		return nil
+	}
+	return &sshLogState{path: path, offset: info.Size(), info: info}
+}
+
+func pollSSHLog(state *sshLogState) error {
+	info, err := os.Stat(state.path)
+	if err != nil {
+		return err
+	}
+	if !os.SameFile(state.info, info) || info.Size() < state.offset {
+		state.offset = 0
+		state.info = info
+	}
+	if info.Size() == state.offset {
+		return nil
+	}
+
+	file, err := os.Open(state.path)
+	if err != nil {
+		return err
+	}
+	defer file.Close()
+	if _, err := file.Seek(state.offset, io.SeekStart); err != nil {
+		return err
+	}
+	scanner := bufio.NewScanner(file)
+	scanner.Buffer(make([]byte, 4096), 64*1024)
+	for scanner.Scan() {
+		if event, ok := parseAcceptedSSHLogin(scanner.Text()); ok {
+			if err := reportAcceptedSSHLogin(event); err != nil {
+				log.Printf("failed to report successful SSH login: %v", err)
+			}
+		}
+	}
+	if err := scanner.Err(); err != nil {
+		return err
+	}
+	state.offset, err = file.Seek(0, io.SeekCurrent)
+	return err
+}
+
+type acceptedSSHLogin struct {
+	user       string
+	remoteIP   string
+	remotePort int
+	authMethod string
+	occurredAt time.Time
+}
+
+func parseAcceptedSSHLogin(line string) (acceptedSSHLogin, bool) {
+	match := acceptedSSHLoginPattern.FindStringSubmatch(line)
+	if len(match) != 5 || net.ParseIP(match[3]) == nil {
+		return acceptedSSHLogin{}, false
+	}
+	port, err := strconv.Atoi(match[4])
+	if err != nil || port < 1 || port > 65535 {
+		return acceptedSSHLogin{}, false
+	}
+	method := strings.ToLower(strings.SplitN(match[1], "/", 2)[0])
+	switch method {
+	case "publickey", "password", "keyboard-interactive", "hostbased":
+	default:
+		return acceptedSSHLogin{}, false
+	}
+	return acceptedSSHLogin{user: match[2], remoteIP: match[3], remotePort: port, authMethod: method, occurredAt: time.Now().UTC()}, true
+}
+
+func reportAcceptedSSHLogin(event acceptedSSHLogin) error {
+	id := fmt.Sprintf("ssh-login-%d", event.occurredAt.UnixNano())
+	payload := v2.NewRequest(id, v2.MethodAgentSSHLogin, map[string]interface{}{
+		"user":        event.user,
+		"remote_ip":   event.remoteIP,
+		"remote_port": event.remotePort,
+		"auth_method": event.authMethod,
+		"occurred_at": event.occurredAt.Format(time.RFC3339Nano),
+	})
+	_, err := postV2Request(payload)
+	return err
+}
