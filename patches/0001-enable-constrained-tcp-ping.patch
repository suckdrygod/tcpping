new file mode 100644
index 0000000..59768a9
--- /dev/null
+++ b/server/vnstat.go
@@ -0,0 +1,171 @@
+package server
+
+import (
+	"context"
+	"encoding/json"
+	"log"
+	"os"
+	"os/exec"
+	"strings"
+	"time"
+)
+
+type vnstatJSON struct {
+	Interfaces []vnstatInterface `json:"interfaces"`
+}
+
+type vnstatInterface struct {
+	Name    string        `json:"name"`
+	Traffic vnstatTraffic `json:"traffic"`
+}
+
+type vnstatTraffic struct {
+	Total vnstatCounter `json:"total"`
+	Day   []vnstatDay   `json:"day"`
+}
+
+type vnstatCounter struct {
+	Rx int64 `json:"rx"`
+	Tx int64 `json:"tx"`
+}
+
+type vnstatDay struct {
+	Date vnstatDate `json:"date"`
+	Rx   int64      `json:"rx"`
+	Tx   int64      `json:"tx"`
+}
+
+type vnstatDate struct {
+	Year  int `json:"year"`
+	Month int `json:"month"`
+	Day   int `json:"day"`
+}
+
+func collectVnstatBasicInfo() map[string]interface{} {
+	info, err := readVnstatJSON()
+	if err != nil {
+		log.Printf("vnStat unavailable: %v", err)
+		return map[string]interface{}{"vnstat_available": false}
+	}
+	iface, ok := selectVnstatInterface(info.Interfaces)
+	if !ok {
+		return map[string]interface{}{"vnstat_available": false}
+	}
+
+	days := make([]map[string]interface{}, 0, len(iface.Traffic.Day))
+	for _, day := range iface.Traffic.Day {
+		if day.Date.Year <= 0 || day.Date.Month <= 0 || day.Date.Day <= 0 {
+			continue
+		}
+		date := time.Date(day.Date.Year, time.Month(day.Date.Month), day.Date.Day, 0, 0, 0, 0, time.UTC)
+		days = append(days, map[string]interface{}{
+			"date": date.Format("2006-01-02"),
+			"up":   day.Tx,
+			"down": day.Rx,
+		})
+	}
+
+	return map[string]interface{}{
+		"vnstat_available":  true,
+		"vnstat_interface":  iface.Name,
+		"vnstat_total_up":   iface.Traffic.Total.Tx,
+		"vnstat_total_down": iface.Traffic.Total.Rx,
+		"vnstat_updated_at": time.Now().UTC().Format(time.RFC3339),
+		"vnstat_days":       days,
+	}
+}
+
+func readVnstatJSON() (vnstatJSON, error) {
+	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
+	defer cancel()
+
+	cmd := exec.CommandContext(ctx, "vnstat", "--json")
+	out, err := cmd.Output()
+	if err != nil {
+		return vnstatJSON{}, err
+	}
+
+	var parsed vnstatJSON
+	if err := json.Unmarshal(out, &parsed); err != nil {
+		return vnstatJSON{}, err
+	}
+	return parsed, nil
+}
+
+func selectVnstatInterface(interfaces []vnstatInterface) (vnstatInterface, bool) {
+	if defaultIface := defaultRouteInterface(); defaultIface != "" {
+		for _, iface := range interfaces {
+			if iface.Name == defaultIface {
+				return iface, true
+			}
+		}
+	}
+
+	if iface, ok := selectLargestVnstatInterface(interfaces, true); ok {
+		return iface, true
+	}
+	return selectLargestVnstatInterface(interfaces, false)
+}
+
+func selectLargestVnstatInterface(interfaces []vnstatInterface, skipVirtual bool) (vnstatInterface, bool) {
+	var selected vnstatInterface
+	found := false
+	var selectedTotal int64
+	for _, iface := range interfaces {
+		if skipVirtual && isLikelyVirtualInterface(iface.Name) {
+			continue
+		}
+		total := iface.Traffic.Total.Rx + iface.Traffic.Total.Tx
+		if !found || total > selectedTotal {
+			selected = iface
+			selectedTotal = total
+			found = true
+		}
+	}
+	return selected, found
+}
+
+var procNetRoutePath = "/proc/net/route"
+
+func defaultRouteInterface() string {
+	raw, err := os.ReadFile(procNetRoutePath)
+	if err != nil {
+		return ""
+	}
+	lines := strings.Split(string(raw), "\n")
+	for _, line := range lines[1:] {
+		fields := strings.Fields(line)
+		if len(fields) < 4 {
+			continue
+		}
+		if fields[1] != "00000000" {
+			continue
+		}
+		return fields[0]
+	}
+	return ""
+}
+
+func isLikelyVirtualInterface(name string) bool {
+	name = strings.ToLower(strings.TrimSpace(name))
+	if name == "" {
+		return true
+	}
+	virtualPrefixes := []string{
+		"br-",
+		"docker",
+		"veth",
+		"virbr",
+		"lo",
+		"tun",
+		"tap",
+		"wg",
+		"tailscale",
+	}
+	for _, prefix := range virtualPrefixes {
+		if strings.HasPrefix(name, prefix) {
+			return true
+		}
+	}
+	return false
+}
diff --git a/server/vnstat_test.go b/server/vnstat_test.go
