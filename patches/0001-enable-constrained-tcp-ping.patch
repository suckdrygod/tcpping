diff --git a/server/safe_tcp_ping.go b/server/safe_tcp_ping.go
new file mode 100644
index 0000000..13860ee
--- /dev/null
+++ b/server/safe_tcp_ping.go
@@ -0,0 +1,255 @@
+package server
+
+import (
+	"bytes"
+	"encoding/json"
+	"errors"
+	"fmt"
+	"io"
+	"log"
+	"net"
+	"net/http"
+	"strconv"
+	"strings"
+	"sync"
+	"time"
+
+	"github.com/komari-monitor/komari-agent/dnsresolver"
+	v2 "github.com/komari-monitor/komari-agent/protocol/v2"
+	"github.com/komari-monitor/komari-agent/ws"
+)
+
+// Safe TCP policy:
+//   * only the "tcp" ping type is implemented;
+//   * an explicit host:port is required;
+//   * host and port must be allow-listed;
+//   * DNS answers are pinned and private/local/reserved addresses are rejected;
+//   * a sliding-window limit prevents the agent being used for high-rate scanning.
+// There is deliberately no ICMP, HTTP, terminal, exec, file-transfer, or shell path.
+
+var safeTCPTaskWindow struct {
+	sync.Mutex
+	accepted []time.Time
+}
+
+func NewSafeTCPPingTask(conn *ws.SafeConn, protocolVersion int, taskID uint, pingType, pingTarget string) {
+	if taskID == 0 {
+		log.Printf("ignored TCP probe without task id")
+		return
+	}
+
+	result := -1
+	if strings.EqualFold(strings.TrimSpace(pingType), "tcp") {
+		if !allowSafeTCPTask() {
+			log.Printf("TCP probe task %d rejected: rate limit", taskID)
+		} else if latency, err := measureSafeTCP(pingTarget); err != nil {
+			log.Printf("TCP probe task %d rejected/failed: %v", taskID, err)
+		} else {
+			result = int(latency.Milliseconds())
+		}
+	} else {
+		log.Printf("TCP probe task %d rejected: ping type %q is not allowed", taskID, pingType)
+	}
+
+	finishedAt := time.Now().UTC()
+	if protocolVersion >= 2 {
+		payload := v2.BuildPingResultPayload(taskID, "tcp", result, finishedAt)
+		if conn != nil {
+			if err := conn.WriteJSON(payload); err != nil {
+				log.Printf("failed to send TCP probe result over WebSocket: %v", err)
+			}
+			return
+		}
+		if err := postSafeTCPPingResult(payload); err != nil {
+			log.Printf("failed to POST TCP probe result: %v", err)
+		}
+		return
+	}
+
+	// v1 supports result delivery only while its report WebSocket is connected.
+	if conn == nil {
+		log.Printf("dropping v1 TCP probe result: no active WebSocket")
+		return
+	}
+	payload := map[string]interface{}{
+		"type":        "ping_result",
+		"task_id":     taskID,
+		"ping_type":   "tcp",
+		"value":       result,
+		"finished_at": finishedAt.Format(time.RFC3339Nano),
+	}
+	if err := conn.WriteJSON(payload); err != nil {
+		log.Printf("failed to send v1 TCP probe result: %v", err)
+	}
+}
+
+func allowSafeTCPTask() bool {
+	now := time.Now()
+	limit := flags.SafeTCPMaxTasksPerMinute
+	if limit < 1 {
+		limit = 30
+	}
+
+	safeTCPTaskWindow.Lock()
+	defer safeTCPTaskWindow.Unlock()
+	cutoff := now.Add(-time.Minute)
+	kept := safeTCPTaskWindow.accepted[:0]
+	for _, t := range safeTCPTaskWindow.accepted {
+		if t.After(cutoff) {
+			kept = append(kept, t)
+		}
+	}
+	safeTCPTaskWindow.accepted = kept
+	if len(safeTCPTaskWindow.accepted) >= limit {
+		return false
+	}
+	safeTCPTaskWindow.accepted = append(safeTCPTaskWindow.accepted, now)
+	return true
+}
+
+func measureSafeTCP(target string) (time.Duration, error) {
+	host, portText, err := net.SplitHostPort(strings.TrimSpace(target))
+	if err != nil {
+		return 0, errors.New("target must be an explicit host:port")
+	}
+	host = strings.TrimSuffix(strings.Trim(strings.TrimSpace(host), "[]"), ".")
+	if host == "" {
+		return 0, errors.New("empty target host")
+	}
+	port, err := strconv.Atoi(portText)
+	if err != nil || port < 1 || port > 65535 {
+		return 0, errors.New("invalid target port")
+	}
+	if !safeTCPHostAllowed(host) {
+		return 0, fmt.Errorf("host %q is not on the TCP probe allow-list", host)
+	}
+	if !safeTCPPortAllowed(port) {
+		return 0, fmt.Errorf("port %d is not on the TCP probe allow-list", port)
+	}
+
+	ips, err := net.LookupIP(host)
+	if err != nil || len(ips) == 0 {
+		return 0, errors.New("unable to resolve target host")
+	}
+	for _, ip := range ips {
+		if !safeTCPPublicIP(ip) {
+			return 0, fmt.Errorf("target resolves to a forbidden address: %s", ip)
+		}
+	}
+
+	timeout := time.Duration(flags.SafeTCPTimeoutSeconds) * time.Second
+	if timeout < time.Second {
+		timeout = 3 * time.Second
+	}
+	if timeout > 10*time.Second {
+		timeout = 10 * time.Second
+	}
+
+	// Pin the validated IP address. Do not dial the hostname after validation,
+	// otherwise a later DNS answer could turn the task into an internal probe.
+	address := net.JoinHostPort(ips[0].String(), strconv.Itoa(port))
+	start := time.Now()
+	conn, err := net.DialTimeout("tcp", address, timeout)
+	if err != nil {
+		return 0, err
+	}
+	_ = conn.Close()
+	return time.Since(start), nil
+}
+
+func safeTCPHostAllowed(host string) bool {
+	normalized := strings.ToLower(strings.TrimSuffix(strings.TrimSpace(host), "."))
+	for _, raw := range strings.Split(flags.SafeTCPAllowHosts, ",") {
+		rule := strings.ToLower(strings.TrimSuffix(strings.TrimSpace(raw), "."))
+		if rule == "" {
+			continue
+		}
+		if strings.HasPrefix(rule, "*.") {
+			suffix := strings.TrimPrefix(rule, "*") // keep leading dot
+			if strings.HasSuffix(normalized, suffix) && normalized != strings.TrimPrefix(suffix, ".") {
+				return true
+			}
+			continue
+		}
+		if normalized == rule {
+			return true
+		}
+	}
+	return false
+}
+
+func safeTCPPortAllowed(port int) bool {
+	for _, raw := range strings.Split(flags.SafeTCPAllowPorts, ",") {
+		value, err := strconv.Atoi(strings.TrimSpace(raw))
+		if err == nil && value == port {
+			return true
+		}
+	}
+	return false
+}
+
+func safeTCPPublicIP(ip net.IP) bool {
+	if ip == nil || ip.IsUnspecified() || ip.IsLoopback() || ip.IsPrivate() ||
+		ip.IsLinkLocalUnicast() || ip.IsLinkLocalMulticast() || ip.IsMulticast() {
+		return false
+	}
+	if v4 := ip.To4(); v4 != nil {
+		switch {
+		case v4[0] == 0: // "this" network
+			return false
+		case v4[0] == 100 && v4[1] >= 64 && v4[1] <= 127: // CGNAT
+			return false
+		case v4[0] == 192 && v4[1] == 0: // IETF protocol assignments
+			return false
+		case v4[0] == 192 && v4[1] == 0 && v4[2] == 2: // TEST-NET-1 (covered above)
+			return false
+		case v4[0] == 198 && (v4[1] == 18 || v4[1] == 19): // benchmarking
+			return false
+		case v4[0] == 198 && v4[1] == 51 && v4[2] == 100: // TEST-NET-2
+			return false
+		case v4[0] == 203 && v4[1] == 0 && v4[2] == 113: // TEST-NET-3
+			return false
+		case v4[0] >= 224: // multicast, reserved, and limited broadcast
+			return false
+		}
+	}
+	return true
+}
+
+func postSafeTCPPingResult(payload interface{}) error {
+	body, err := json.Marshal(payload)
+	if err != nil {
+		return err
+	}
+	compressed := false
+	if !flags.DisableCompression {
+		if gz, err := gzipBytes(body); err == nil {
+			body = gz
+			compressed = true
+		}
+	}
+	endpoint := strings.TrimSuffix(flags.Endpoint, "/") + "/api/clients/v2/rpc?token=" + flags.Token
+	req, err := http.NewRequest(http.MethodPost, endpoint, bytes.NewReader(body))
+	if err != nil {
+		return err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	if compressed {
+		req.Header.Set("Content-Encoding", "gzip")
+	}
+	if flags.CFAccessClientID != "" && flags.CFAccessClientSecret != "" {
+		req.Header.Set("CF-Access-Client-Id", flags.CFAccessClientID)
+		req.Header.Set("CF-Access-Client-Secret", flags.CFAccessClientSecret)
+	}
+	client := dnsresolver.GetHTTPClientWithPreference(30*time.Second, flags.PreferIPVersion)
+	resp, err := client.Do(req)
+	if err != nil {
+		return err
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode != http.StatusOK {
+		data, _ := io.ReadAll(io.LimitReader(resp.Body, 2048))
+		return fmt.Errorf("status %s: %s", resp.Status, strings.TrimSpace(string(data)))
+	}
+	return nil
+}
