+package server
+
+import "testing"
+
+func TestParseAcceptedSSHLogin(t *testing.T) {
+	tests := []struct {
+		line   string
+		ok     bool
+		method string
+	}{
+		{"Jun 21 host sshd[123]: Accepted publickey for root from 203.0.113.5 port 4567 ssh2", true, "publickey"},
+		{"Jun 21 host sshd[124]: Accepted keyboard-interactive/pam for admin from 2001:db8::5 port 22 ssh2", true, "keyboard-interactive"},
+		{"Jun 21 host sshd[125]: Failed password for root from 203.0.113.5 port 4567 ssh2", false, ""},
+		{"Jun 21 host sshd[126]: Accepted publickey for bad<user from 203.0.113.5 port 4567 ssh2", false, ""},
+	}
+	for _, test := range tests {
+		event, ok := parseAcceptedSSHLogin(test.line)
+		if ok != test.ok {
+			t.Fatalf("parse result for %q: got %v want %v", test.line, ok, test.ok)
+		}
+		if ok && event.authMethod != test.method {
+			t.Fatalf("method for %q: got %q want %q", test.line, event.authMethod, test.method)
+		}
+	}
+}
