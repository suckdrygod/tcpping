@@ -0,0 +1,40 @@
+package server
+
+import "testing"
+
+func TestExecuteSecurityActionValidation(t *testing.T) {
+	if status, _ := executeSecurityAction(securityAction{ID: "1", IP: "not-an-ip", Action: "ban", Duration: 3600}); status != "failed" {
+		t.Fatalf("invalid IP status = %q", status)
+	}
+	if status, _ := executeSecurityAction(securityAction{ID: "2", IP: "203.0.113.10", Action: "rm -rf /", Duration: 3600}); status != "failed" {
+		t.Fatalf("invalid action status = %q", status)
+	}
+}
+
+func TestExecuteSecurityActionWhitelistAndDryRun(t *testing.T) {
+	oldDryRun := flags.SSHAuthBanDryRun
+	oldWhitelist := flags.SSHAuthBanWhitelist
+	oldDuration := flags.SSHAuthBanDuration
+	oldMode := flags.SSHAuthBanMode
+	defer func() {
+		flags.SSHAuthBanDryRun = oldDryRun
+		flags.SSHAuthBanWhitelist = oldWhitelist
+		flags.SSHAuthBanDuration = oldDuration
+		flags.SSHAuthBanMode = oldMode
+	}()
+
+	flags.SSHAuthBanDryRun = true
+	flags.SSHAuthBanWhitelist = "198.51.100.0/24"
+	flags.SSHAuthBanDuration = 3600
+	flags.SSHAuthBanMode = "nftables"
+
+	if status, message := executeSecurityAction(securityAction{ID: "1", IP: "198.51.100.7", Action: "ban", Duration: 3600}); status != "skipped" || message != "whitelisted" {
+		t.Fatalf("whitelist result = %q %q", status, message)
+	}
+	if status, message := executeSecurityAction(securityAction{ID: "2", IP: "203.0.113.10", Action: "ban", Duration: 3600}); status != "success" || message == "" {
+		t.Fatalf("dry-run ban result = %q %q", status, message)
+	}
+	if status, message := executeSecurityAction(securityAction{ID: "3", IP: "203.0.113.10", Action: "unban", Duration: 3600}); status != "success" || message == "" {
+		t.Fatalf("dry-run unban result = %q %q", status, message)
+	}
+}
diff --git a/server/ssh_auth_guard.go b/server/ssh_auth_guard.go
new file mode 100644
index 0000000..bf1ee8a
--- /dev/null
+++ b/server/ssh_auth_guard.go
@@ -0,0 +1,598 @@
+package server
+
+import (
+	"bufio"
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"log"
+	"net"
+	"net/http"
+	"os"
+	"os/exec"
+	"regexp"
+	"strings"
+	"sync"
+	"time"
+	"unicode"
+
+	"github.com/komari-monitor/komari-agent/dnsresolver"
+)
+
+var (
+	failedPasswordPattern  = regexp.MustCompile(`Failed password for (?:invalid user )?([^ ]+) from ([0-9A-Fa-f:.]+)`)
+	invalidUserPattern     = regexp.MustCompile(`Invalid user ([^ ]+) from ([0-9A-Fa-f:.]+)`)
+	failedPublicKeyPattern = regexp.MustCompile(`Failed publickey for (?:invalid user )?([^ ]+) from ([0-9A-Fa-f:.]+)`)
+	pamFailureRhostPattern = regexp.MustCompile(`\brhost=([0-9A-Fa-f:.]+)`)
+	pamFailureUserPattern  = regexp.MustCompile(`\buser=([^ ]+)`)
+)
+
+type sshAuthFailure struct {
+	sourceIP      string
+	user          string
+	method        string
+	occurredAt    time.Time
+	sampleMessage string
+}
+
+type sshAuthGuardAlert struct {
+	sourceIP      string
+	user          string
+	method        string
+	failedCount   int
+	windowSeconds int
+	occurredAt    time.Time
+	sampleMessage string
+	banStatus     string
+}
+
+type sshAuthGuard struct {
+	threshold     int
+	window        time.Duration
+	cooldown      time.Duration
+	rootOnly      bool
+	aggregateByIP bool
+	banPolicy     *sshAuthBanPolicy
+	report        func(sshAuthGuardAlert) error
+	now           func() time.Time
+	buckets       map[string][]sshAuthFailure
+	lastAlert     map[string]time.Time
+}
+
+type sshAuthBanPolicy struct {
+	enabled         bool
+	after           int
+	duration        time.Duration
+	mode            string
+	dryRun          bool
+	whitelist       []net.IPNet
+	bannedMu        sync.Mutex
+	bannedUntilByIP map[string]time.Time
+}
+
+// StartSSHAuthGuard is a read-only, alert-only SSH authentication failure
+// monitor. It does not modify PAM, sshd, firewall rules, or any other system
+// configuration.
+func StartSSHAuthGuard(ctx context.Context) {
+	guard := newSSHAuthGuardFromFlags()
+	if _, err := exec.LookPath("journalctl"); err == nil {
+		go watchSSHAuthGuardJournal(ctx, guard)
+		return
+	}
+	log.Printf("SSH auth guard journal fallback unavailable: journalctl not found")
+	watchSSHAuthGuardFiles(ctx, guard)
+}
+
+func newSSHAuthGuardFromFlags() *sshAuthGuard {
+	threshold := flags.SSHAuthThreshold
+	if threshold == 0 {
+		threshold = 5
+	}
+	windowSeconds := flags.SSHAuthWindowSeconds
+	if windowSeconds == 0 {
+		windowSeconds = 60
+	}
+	cooldownSeconds := flags.SSHAuthCooldownSeconds
+	if cooldownSeconds == 0 {
+		cooldownSeconds = 1800
+	}
+	return newSSHAuthGuard(threshold, time.Duration(windowSeconds)*time.Second, time.Duration(cooldownSeconds)*time.Second, flags.SSHAuthRootOnly, flags.SSHAuthAggregateByIP, newSSHAuthBanPolicyFromFlags(), reportSSHAuthGuardAlert)
+}
+
+func newSSHAuthGuard(threshold int, window, cooldown time.Duration, rootOnly bool, aggregateByIP bool, banPolicy *sshAuthBanPolicy, report func(sshAuthGuardAlert) error) *sshAuthGuard {
+	if threshold <= 0 {
+		threshold = 5
+	}
+	if window <= 0 {
+		window = time.Minute
+	}
+	if cooldown <= 0 {
+		cooldown = 30 * time.Minute
+	}
+	if report == nil {
+		report = func(sshAuthGuardAlert) error { return nil }
+	}
+	return &sshAuthGuard{
+		threshold:     threshold,
+		window:        window,
+		cooldown:      cooldown,
+		rootOnly:      rootOnly,
+		aggregateByIP: aggregateByIP,
+		banPolicy:     banPolicy,
+		report:        report,
+		now:           time.Now,
+		buckets:       make(map[string][]sshAuthFailure),
+		lastAlert:     make(map[string]time.Time),
+	}
+}
+
+func newSSHAuthBanPolicyFromFlags() *sshAuthBanPolicy {
+	policy := &sshAuthBanPolicy{
+		enabled:         flags.SSHAuthBanEnable,
+		after:           flags.SSHAuthBanAfter,
+		duration:        time.Duration(flags.SSHAuthBanDuration) * time.Second,
+		mode:            flags.SSHAuthBanMode,
+		dryRun:          flags.SSHAuthBanDryRun,
+		bannedUntilByIP: make(map[string]time.Time),
+	}
+	if policy.after <= 0 {
+		policy.after = 5
+	}
+	if policy.duration <= 0 {
+		policy.duration = time.Hour
+	}
+	if strings.TrimSpace(policy.mode) == "" {
+		policy.mode = "nftables"
+	}
+	policy.whitelist = parseSSHAuthBanWhitelist(flags.SSHAuthBanWhitelist)
+	return policy
+}
+
+func watchSSHAuthGuardJournal(ctx context.Context, guard *sshAuthGuard) {
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		default:
+		}
+		if err := runSSHAuthGuardJournal(ctx, guard); err != nil && ctx.Err() == nil {
+			log.Printf("SSH auth guard journal watcher stopped: %v", err)
+			select {
+			case <-ctx.Done():
+				return
+			case <-time.After(10 * time.Second):
+			}
+		}
+	}
+}
+
+func runSSHAuthGuardJournal(ctx context.Context, guard *sshAuthGuard) error {
+	cmd := exec.CommandContext(ctx, "journalctl", "-u", "ssh", "-u", "sshd", "-f", "-o", "short-iso")
+	stdout, err := cmd.StdoutPipe()
+	if err != nil {
+		return err
+	}
+	cmd.Stderr = io.Discard
+	if err := cmd.Start(); err != nil {
+		return err
+	}
+	log.Printf("SSH auth guard watching systemd journal")
+	err = scanSSHAuthGuardLines(stdout, guard)
+	waitErr := cmd.Wait()
+	if err != nil {
+		return err
+	}
+	return waitErr
+}
+
+func watchSSHAuthGuardFiles(ctx context.Context, guard *sshAuthGuard) {
+	paths := []string{"/var/log/auth.log", "/var/log/secure"}
+	states := make(map[string]*sshLogState, len(paths))
+	for _, path := range paths {
+		if state := openSSHLogAtEnd(path); state != nil {
+			states[path] = state
+			log.Printf("SSH auth guard watching %s", path)
+		}
+	}
+	if len(states) == 0 {
+		log.Printf("SSH auth guard waiting for /var/log/auth.log or /var/log/secure")
+	}
+
+	ticker := time.NewTicker(2 * time.Second)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case <-ticker.C:
+			for _, path := range paths {
+				state := states[path]
+				if state == nil {
+					if next := openSSHLogAtEnd(path); next != nil {
+						states[path] = next
+						log.Printf("SSH auth guard watching %s", path)
+					}
+					continue
+				}
+				if err := pollSSHAuthGuardFile(state, guard); err != nil && !os.IsNotExist(err) {
+					log.Printf("SSH auth guard failed to read %s: %v", path, err)
+				}
+			}
+		}
+	}
+}
+
+func pollSSHAuthGuardFile(state *sshLogState, guard *sshAuthGuard) error {
+	info, err := os.Stat(state.path)
+	if err != nil {
+		return err
+	}
+	if !os.SameFile(state.info, info) || info.Size() < state.offset {
+		state.offset = 0
+		state.info = info
+	}
+	if info.Size() == state.offset {
+		return nil
+	}
+
+	file, err := os.Open(state.path)
+	if err != nil {
+		return err
+	}
+	defer file.Close()
+	if _, err := file.Seek(state.offset, io.SeekStart); err != nil {
+		return err
+	}
+	if err := scanSSHAuthGuardLines(file, guard); err != nil {
+		return err
+	}
+	state.offset, err = file.Seek(0, io.SeekCurrent)
+	return err
+}
+
+func scanSSHAuthGuardLines(reader io.Reader, guard *sshAuthGuard) error {
+	scanner := bufio.NewScanner(reader)
+	scanner.Buffer(make([]byte, 4096), 64*1024)
+	for scanner.Scan() {
+		if failure, ok := parseSSHAuthFailure(scanner.Text(), guard.now()); ok {
+			guard.Observe(failure)
+		}
+	}
+	return scanner.Err()
+}
+
+func parseSSHAuthFailure(line string, now time.Time) (sshAuthFailure, bool) {
+	for _, parser := range []struct {
+		method  string
+		pattern *regexp.Regexp
+	}{
+		{method: "password", pattern: failedPasswordPattern},
+		{method: "invalid-user", pattern: invalidUserPattern},
+		{method: "publickey", pattern: failedPublicKeyPattern},
+	} {
+		match := parser.pattern.FindStringSubmatch(line)
+		if len(match) == 3 && net.ParseIP(match[2]) != nil {
+			return sshAuthFailure{
+				sourceIP:      match[2],
+				user:          sanitizeSSHAuthGuardToken(match[1], "unknown"),
+				method:        parser.method,
+				occurredAt:    now.UTC(),
+				sampleMessage: sanitizeSSHAuthGuardSample(line),
+			}, true
+		}
+	}
+
+	if strings.Contains(line, "pam_unix(sshd:auth): authentication failure") {
+		ipMatch := pamFailureRhostPattern.FindStringSubmatch(line)
+		if len(ipMatch) != 2 || net.ParseIP(ipMatch[1]) == nil {
+			return sshAuthFailure{}, false
+		}
+		user := "unknown"
+		if userMatch := pamFailureUserPattern.FindStringSubmatch(line); len(userMatch) == 2 {
+			user = sanitizeSSHAuthGuardToken(userMatch[1], "unknown")
+		}
+		return sshAuthFailure{
+			sourceIP:      ipMatch[1],
+			user:          user,
+			method:        "pam",
+			occurredAt:    now.UTC(),
+			sampleMessage: sanitizeSSHAuthGuardSample(line),
+		}, true
+	}
+	return sshAuthFailure{}, false
+}
+
+func (g *sshAuthGuard) Observe(failure sshAuthFailure) {
+	if g.rootOnly && failure.user != "root" {
+		return
+	}
+	key := g.bucketKey(failure)
+	cutoff := failure.occurredAt.Add(-g.window)
+	bucket := g.buckets[key][:0]
+	for _, item := range g.buckets[key] {
+		if !item.occurredAt.Before(cutoff) {
+			bucket = append(bucket, item)
+		}
+	}
+	bucket = append(bucket, failure)
+	g.buckets[key] = bucket
+
+	if len(bucket) < g.threshold {
+		return
+	}
+	if last, ok := g.lastAlert[key]; ok && failure.occurredAt.Sub(last) < g.cooldown {
+		return
+	}
+	g.lastAlert[key] = failure.occurredAt
+	userText := failure.user
+	methodText := failure.method
+	if g.aggregateByIP {
+		userText = joinSSHAuthGuardUsers(bucket)
+		methodText = joinSSHAuthGuardMethods(bucket)
+	}
+	banStatus := "未启用自动封禁"
+	if g.banPolicy != nil {
+		banStatus = g.banPolicy.MaybeBan(failure.sourceIP, len(bucket), failure.occurredAt)
+	}
+	if err := g.report(sshAuthGuardAlert{
+		sourceIP:      failure.sourceIP,
+		user:          userText,
+		method:        methodText,
+		failedCount:   len(bucket),
+		windowSeconds: int(g.window / time.Second),
+		occurredAt:    failure.occurredAt,
+		sampleMessage: failure.sampleMessage,
+		banStatus:     banStatus,
+	}); err != nil {
+		log.Printf("failed to report SSH auth guard alert: %v", err)
+	}
+}
+
+func (g *sshAuthGuard) bucketKey(failure sshAuthFailure) string {
+	if g.aggregateByIP {
+		return failure.sourceIP
+	}
+	return failure.sourceIP + "|" + failure.user
+}
+
+func joinSSHAuthGuardUsers(bucket []sshAuthFailure) string {
+	return joinSSHAuthGuardValues(bucket, func(f sshAuthFailure) string { return f.user })
+}
+
+func joinSSHAuthGuardMethods(bucket []sshAuthFailure) string {
+	return joinSSHAuthGuardValues(bucket, func(f sshAuthFailure) string { return f.method })
+}
+
+func joinSSHAuthGuardValues(bucket []sshAuthFailure, pick func(sshAuthFailure) string) string {
+	seen := make(map[string]bool, len(bucket))
+	values := make([]string, 0, len(bucket))
+	for _, failure := range bucket {
+		value := strings.TrimSpace(pick(failure))
+		if value == "" || seen[value] {
+			continue
+		}
+		seen[value] = true
+		values = append(values, value)
+	}
+	if len(values) == 0 {
+		return "unknown"
+	}
+	return strings.Join(values, ", ")
+}
+
+func reportSSHAuthGuardAlert(alert sshAuthGuardAlert) error {
+	payload, err := json.Marshal(map[string]interface{}{
+		"source_ip":      alert.sourceIP,
+		"user":           alert.user,
+		"method":         alert.method,
+		"failed_count":   alert.failedCount,
+		"window_seconds": alert.windowSeconds,
+		"occurred_at":    alert.occurredAt.Format(time.RFC3339Nano),
+		"sample_message": alert.sampleMessage,
+		"ban_status":     alert.banStatus,
+	})
+	if err != nil {
+		return err
+	}
+	endpoint := strings.TrimSuffix(flags.Endpoint, "/") + "/api/clients/ssh-auth-guard?token=" + flags.Token
+	req, err := http.NewRequest(http.MethodPost, endpoint, bytes.NewReader(payload))
+	if err != nil {
+		return err
+	}
+	req.Header.Set("Content-Type", "application/json")
+	if flags.CFAccessClientID != "" && flags.CFAccessClientSecret != "" {
+		req.Header.Set("CF-Access-Client-Id", flags.CFAccessClientID)
+		req.Header.Set("CF-Access-Client-Secret", flags.CFAccessClientSecret)
+	}
+	client := dnsresolver.GetHTTPClientWithPreference(15*time.Second, flags.PreferIPVersion)
+	resp, err := client.Do(req)
+	if err != nil {
+		return err
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode < http.StatusOK || resp.StatusCode >= http.StatusMultipleChoices {
+		data, _ := io.ReadAll(io.LimitReader(resp.Body, 1024))
+		return fmt.Errorf("status %s: %s", resp.Status, strings.TrimSpace(string(data)))
+	}
+	return nil
+}
+
+func parseSSHAuthBanWhitelist(raw string) []net.IPNet {
+	parts := strings.Split(raw, ",")
+	ranges := make([]net.IPNet, 0, len(parts))
+	for _, part := range parts {
+		part = strings.TrimSpace(part)
+		if part == "" {
+			continue
+		}
+		if ip := net.ParseIP(part); ip != nil {
+			bits := 32
+			if ip.To4() == nil {
+				bits = 128
+			}
+			ranges = append(ranges, net.IPNet{IP: ip, Mask: net.CIDRMask(bits, bits)})
+			continue
+		}
+		if _, cidr, err := net.ParseCIDR(part); err == nil {
+			ranges = append(ranges, *cidr)
+		}
+	}
+	return ranges
+}
+
+func (p *sshAuthBanPolicy) MaybeBan(sourceIP string, failedCount int, now time.Time) string {
+	if p == nil || !p.enabled {
+		return "未启用自动封禁"
+	}
+	if failedCount < p.after {
+		return "未达到自动封禁阈值"
+	}
+	ip := net.ParseIP(sourceIP)
+	if ip == nil {
+		return "封禁失败：来源 IP 无效"
+	}
+	if p.isWhitelisted(ip) {
+		return "白名单已跳过"
+	}
+	p.bannedMu.Lock()
+	if until, ok := p.bannedUntilByIP[sourceIP]; ok && until.After(now) {
+		remaining := int(until.Sub(now).Seconds())
+		p.bannedMu.Unlock()
+		return fmt.Sprintf("已封禁 %d 秒", remaining)
+	}
+	p.bannedUntilByIP[sourceIP] = now.Add(p.duration)
+	p.bannedMu.Unlock()
+
+	if p.dryRun {
+		log.Printf("SSH auth guard dry-run would ban %s for %s", sourceIP, p.duration)
+		return fmt.Sprintf("dry-run：将封禁 %d 秒", int(p.duration/time.Second))
+	}
+	if p.mode != "nftables" {
+		return "封禁失败：仅支持 nftables"
+	}
+	if err := applySSHAuthNftablesBan(sourceIP, p.duration); err != nil {
+		return "封禁失败：" + sanitizeSSHAuthGuardSample(err.Error())
+	}
+	return fmt.Sprintf("已封禁 %d 秒", int(p.duration/time.Second))
+}
+
+func (p *sshAuthBanPolicy) isWhitelisted(ip net.IP) bool {
+	for _, cidr := range p.whitelist {
+		if cidr.Contains(ip) {
+			return true
+		}
+	}
+	return false
+}
+
+func applySSHAuthNftablesBan(sourceIP string, duration time.Duration) error {
+	ip := net.ParseIP(sourceIP)
+	if ip == nil {
+		return fmt.Errorf("invalid source IP")
+	}
+	family, setName, setType := nftablesAddressSet(ip)
+	timeout := fmt.Sprintf("%ds", int(duration/time.Second))
+	if err := ensureSSHAuthNftablesSet(family, setName, setType); err != nil {
+		return err
+	}
+	return runSSHAuthNft([]string{"add", "element", "inet", "komari_auth_guard", setName, "{", sourceIP, "timeout", timeout, "}"}, true)
+}
+
+func removeSSHAuthNftablesBan(sourceIP string) error {
+	ip := net.ParseIP(sourceIP)
+	if ip == nil {
+		return fmt.Errorf("invalid source IP")
+	}
+	_, setName, _ := nftablesAddressSet(ip)
+	return runSSHAuthNft([]string{"delete", "element", "inet", "komari_auth_guard", setName, "{", sourceIP, "}"}, true)
+}
+
+func ensureSSHAuthNftablesSet(family, setName, setType string) error {
+	setupCommands := [][]string{
+		{"add", "table", "inet", "komari_auth_guard"},
+		{"add", "set", "inet", "komari_auth_guard", setName, "{", "type", setType, ";", "flags", "timeout", ";", "}"},
+		{"add", "chain", "inet", "komari_auth_guard", "input", "{", "type", "filter", "hook", "input", "priority", "-100", ";", "policy", "accept", ";", "}"},
+		{"add", "rule", "inet", "komari_auth_guard", "input", family, "saddr", "@" + setName, "tcp", "dport", "22", "drop"},
+	}
+	for _, args := range setupCommands {
+		if err := runSSHAuthNft(args, true); err != nil {
+			return err
+		}
+	}
+	return nil
+}
+
+func nftablesAddressSet(ip net.IP) (family, setName, setType string) {
+	if ip.To4() == nil {
+		return "ip6", "blocked6", "ipv6_addr"
+	}
+	return "ip", "blocked4", "ipv4_addr"
+}
+
+func runSSHAuthNft(args []string, ignoreExists bool) error {
+	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
+	defer cancel()
+	cmd := exec.CommandContext(ctx, "nft", args...)
+	out, err := cmd.CombinedOutput()
+	output := strings.TrimSpace(string(out))
+	if err == nil {
+		return nil
+	}
+	if ignoreExists && strings.Contains(output, "File exists") {
+		return nil
+	}
+	if ignoreExists && (strings.Contains(output, "No such file or directory") || strings.Contains(output, "No such file")) {
+		return nil
+	}
+	if output == "" {
+		return err
+	}
+	return fmt.Errorf("%v: %s", err, output)
+}
+
+func sanitizeSSHAuthGuardToken(value, fallback string) string {
+	value = strings.TrimSpace(value)
+	if value == "" {
+		return fallback
+	}
+	var b strings.Builder
+	for _, r := range value {
+		if r == '.' || r == '_' || r == '-' || ('0' <= r && r <= '9') || ('A' <= r && r <= 'Z') || ('a' <= r && r <= 'z') {
+			b.WriteRune(r)
+		} else {
+			b.WriteByte('_')
+		}
+		if b.Len() >= 64 {
+			break
+		}
+	}
+	result := strings.Trim(b.String(), "_")
+	if result == "" {
+		return fallback
+	}
+	return result
+}
+
+func sanitizeSSHAuthGuardSample(line string) string {
+	line = strings.TrimSpace(line)
+	if line == "" {
+		return ""
+	}
+	var b strings.Builder
+	for _, r := range line {
+		if r == '\n' || r == '\r' || r == '\t' {
+			b.WriteByte(' ')
+			continue
+		}
+		if unicode.IsControl(r) {
+			continue
+		}
+		b.WriteRune(r)
+		if b.Len() >= 240 {
+			break
+		}
+	}
+	return strings.TrimSpace(b.String())
+}
diff --git a/server/ssh_auth_guard_test.go b/server/ssh_auth_guard_test.go
new file mode 100644
index 0000000..b6f8304
--- /dev/null
+++ b/server/ssh_auth_guard_test.go
@@ -0,0 +1,112 @@
+package server
+
+import (
+	"testing"
+	"time"
+)
+
+func TestParseSSHAuthFailure(t *testing.T) {
+	now := time.Date(2026, 6, 23, 12, 0, 0, 0, time.UTC)
+	tests := []struct {
+		line   string
+		user   string
+		ip     string
+		method string
+	}{
+		{"Jun 23 12:00:00 host sshd[1]: Failed password for root from 203.0.113.5 port 22 ssh2", "root", "203.0.113.5", "password"},
+		{"2026-06-23T12:00:00 host sshd[2]: Failed password for invalid user admin from 2001:db8::10 port 22 ssh2", "admin", "2001:db8::10", "password"},
+		{"Invalid user test from 198.51.100.7 port 3322", "test", "198.51.100.7", "invalid-user"},
+		{"Failed publickey for ubuntu from 198.51.100.8 port 22 ssh2", "ubuntu", "198.51.100.8", "publickey"},
+		{"pam_unix(sshd:auth): authentication failure; rhost=203.0.113.9 user=root", "root", "203.0.113.9", "pam"},
+	}
+	for _, test := range tests {
+		failure, ok := parseSSHAuthFailure(test.line, now)
+		if !ok {
+			t.Fatalf("expected parse success for %q", test.line)
+		}
+		if failure.user != test.user || failure.sourceIP != test.ip || failure.method != test.method {
+			t.Fatalf("unexpected parse result: %#v", failure)
+		}
+	}
+}
+
+func TestSSHAuthGuardThresholdAndCooldown(t *testing.T) {
+	var alerts []sshAuthGuardAlert
+	guard := newSSHAuthGuard(5, time.Minute, 10*time.Minute, false, false, nil, func(alert sshAuthGuardAlert) error {
+		alerts = append(alerts, alert)
+		return nil
+	})
+	base := time.Date(2026, 6, 23, 12, 0, 0, 0, time.UTC)
+	for i := 0; i < 5; i++ {
+		guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base.Add(time.Duration(i) * time.Second)})
+	}
+	if len(alerts) != 1 {
+		t.Fatalf("expected one alert, got %d", len(alerts))
+	}
+	if alerts[0].failedCount != 5 || alerts[0].windowSeconds != 60 {
+		t.Fatalf("unexpected alert: %#v", alerts[0])
+	}
+	for i := 0; i < 5; i++ {
+		guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base.Add(time.Duration(30+i) * time.Second)})
+	}
+	if len(alerts) != 1 {
+		t.Fatalf("cooldown should suppress duplicate alert, got %d", len(alerts))
+	}
+	for i := 0; i < 5; i++ {
+		guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base.Add(11*time.Minute + time.Duration(i)*time.Second)})
+	}
+	if len(alerts) != 2 {
+		t.Fatalf("expected alert after cooldown, got %d", len(alerts))
+	}
+}
+
+func TestSSHAuthGuardAggregateByIP(t *testing.T) {
+	var alerts []sshAuthGuardAlert
+	guard := newSSHAuthGuard(3, time.Minute, 10*time.Minute, false, true, nil, func(alert sshAuthGuardAlert) error {
+		alerts = append(alerts, alert)
+		return nil
+	})
+	base := time.Date(2026, 6, 23, 12, 0, 0, 0, time.UTC)
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base})
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "ubuntu", method: "password", occurredAt: base.Add(time.Second)})
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "admin", method: "invalid-user", occurredAt: base.Add(2 * time.Second)})
+	if len(alerts) != 1 {
+		t.Fatalf("expected one aggregate alert, got %d", len(alerts))
+	}
+	if alerts[0].user != "root, ubuntu, admin" {
+		t.Fatalf("unexpected aggregate users: %q", alerts[0].user)
+	}
+}
+
+func TestSSHAuthBanPolicyDryRunAndWhitelist(t *testing.T) {
+	policy := &sshAuthBanPolicy{enabled: true, after: 2, duration: time.Hour, mode: "nftables", dryRun: true, whitelist: parseSSHAuthBanWhitelist("198.51.100.0/24"), bannedUntilByIP: make(map[string]time.Time)}
+	now := time.Date(2026, 6, 23, 12, 0, 0, 0, time.UTC)
+	if got := policy.MaybeBan("198.51.100.7", 2, now); got != "白名单已跳过" {
+		t.Fatalf("whitelist status = %q", got)
+	}
+	if got := policy.MaybeBan("203.0.113.7", 2, now); got != "dry-run：将封禁 3600 秒" {
+		t.Fatalf("dry-run status = %q", got)
+	}
+	if got := policy.MaybeBan("203.0.113.7", 2, now.Add(time.Minute)); got != "已封禁 3540 秒" {
+		t.Fatalf("repeat status = %q", got)
+	}
+}
+
+func TestSSHAuthGuardRootOnly(t *testing.T) {
+	var alerts []sshAuthGuardAlert
+	guard := newSSHAuthGuard(2, time.Minute, 10*time.Minute, true, false, nil, func(alert sshAuthGuardAlert) error {
+		alerts = append(alerts, alert)
+		return nil
+	})
+	base := time.Date(2026, 6, 23, 12, 0, 0, 0, time.UTC)
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "ubuntu", method: "password", occurredAt: base})
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "ubuntu", method: "password", occurredAt: base.Add(time.Second)})
+	if len(alerts) != 0 {
+		t.Fatalf("non-root failures should be ignored in root-only mode")
+	}
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base})
+	guard.Observe(sshAuthFailure{sourceIP: "203.0.113.5", user: "root", method: "password", occurredAt: base.Add(time.Second)})
+	if len(alerts) != 1 {
+		t.Fatalf("root failures should trigger alert, got %d", len(alerts))
+	}
+}
diff --git a/server/ssh_login_watch.go b/server/ssh_login_watch.go
new file mode 100644
index 0000000..9317c4a
--- /dev/null
+++ b/server/ssh_login_watch.go
@@ -0,0 +1,203 @@
+package server
+
+import (
+	"bufio"
+	"context"
+	"fmt"
+	"io"
+	"log"
+	"net"
+	"os"
+	"os/exec"
+	"regexp"
+	"strconv"
+	"strings"
+	"time"
+
+	v2 "github.com/komari-monitor/komari-agent/protocol/v2"
+)
+
+var acceptedSSHLoginPattern = regexp.MustCompile(`(?:sshd(?:\[[0-9]+\])?: )?Accepted ([^ ]+) for ([A-Za-z0-9._-]+) from ([0-9A-Fa-f:.]+) port ([0-9]+)`)
+
+type sshLogState struct {
+	path   string
+	offset int64
+	info   os.FileInfo
+}
+
+// StartSSHLoginWatcher tails only successful OpenSSH authentication records.
+// It never writes SSH configuration and never executes a command. Existing
+// log contents are skipped on startup so an agent restart cannot replay old
+// login events.
+func StartSSHLoginWatcher(ctx context.Context) {
+	paths := []string{"/var/log/auth.log", "/var/log/secure"}
+	states := make(map[string]*sshLogState, len(paths))
+	for _, path := range paths {
+		if state := openSSHLogAtEnd(path); state != nil {
+			states[path] = state
+			log.Printf("SSH login notifier watching %s", path)
+		}
+	}
+	if len(states) == 0 {
+		log.Printf("SSH login notifier waiting for /var/log/auth.log or /var/log/secure")
+		go watchSSHLoginJournal(ctx)
+	}
+
+	ticker := time.NewTicker(2 * time.Second)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case <-ticker.C:
+			for _, path := range paths {
+				state := states[path]
+				if state == nil {
+					if next := openSSHLogAtEnd(path); next != nil {
+						states[path] = next
+						log.Printf("SSH login notifier watching %s", path)
+					}
+					continue
+				}
+				if err := pollSSHLog(state); err != nil && !os.IsNotExist(err) {
+					log.Printf("SSH login notifier failed to read %s: %v", path, err)
+				}
+			}
+		}
+	}
+}
+
+func watchSSHLoginJournal(ctx context.Context) {
+	if _, err := exec.LookPath("journalctl"); err != nil {
+		log.Printf("SSH login notifier journal fallback unavailable: journalctl not found")
+		return
+	}
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		default:
+		}
+		if err := runSSHLoginJournal(ctx); err != nil && ctx.Err() == nil {
+			log.Printf("SSH login notifier journal fallback stopped: %v", err)
+			select {
+			case <-ctx.Done():
+				return
+			case <-time.After(5 * time.Second):
+			}
+		}
+	}
+}
+
+func runSSHLoginJournal(ctx context.Context) error {
+	cmd := exec.CommandContext(ctx, "journalctl", "-f", "-n", "0", "-o", "cat")
+	stdout, err := cmd.StdoutPipe()
+	if err != nil {
+		return err
+	}
+	cmd.Stderr = io.Discard
+	if err := cmd.Start(); err != nil {
+		return err
+	}
+	log.Printf("SSH login notifier watching systemd journal")
+
+	scanner := bufio.NewScanner(stdout)
+	scanner.Buffer(make([]byte, 4096), 64*1024)
+	for scanner.Scan() {
+		if event, ok := parseAcceptedSSHLogin(scanner.Text()); ok {
+			if err := reportAcceptedSSHLogin(event); err != nil {
+				log.Printf("failed to report successful SSH login: %v", err)
+			}
+		}
+	}
+	scanErr := scanner.Err()
+	waitErr := cmd.Wait()
+	if scanErr != nil {
+		return scanErr
+	}
+	return waitErr
+}
+
+func openSSHLogAtEnd(path string) *sshLogState {
+	info, err := os.Stat(path)
+	if err != nil || !info.Mode().IsRegular() {
+		return nil
+	}
+	return &sshLogState{path: path, offset: info.Size(), info: info}
+}
+
+func pollSSHLog(state *sshLogState) error {
+	info, err := os.Stat(state.path)
+	if err != nil {
+		return err
+	}
+	if !os.SameFile(state.info, info) || info.Size() < state.offset {
+		state.offset = 0
+		state.info = info
+	}
+	if info.Size() == state.offset {
+		return nil
+	}
+
+	file, err := os.Open(state.path)
+	if err != nil {
+		return err
+	}
+	defer file.Close()
+	if _, err := file.Seek(state.offset, io.SeekStart); err != nil {
+		return err
+	}
+	scanner := bufio.NewScanner(file)
+	scanner.Buffer(make([]byte, 4096), 64*1024)
+	for scanner.Scan() {
+		if event, ok := parseAcceptedSSHLogin(scanner.Text()); ok {
+			if err := reportAcceptedSSHLogin(event); err != nil {
+				log.Printf("failed to report successful SSH login: %v", err)
+			}
+		}
+	}
+	if err := scanner.Err(); err != nil {
+		return err
+	}
+	state.offset, err = file.Seek(0, io.SeekCurrent)
+	return err
+}
+
+type acceptedSSHLogin struct {
+	user       string
+	remoteIP   string
+	remotePort int
+	authMethod string
+	occurredAt time.Time
+}
+
+func parseAcceptedSSHLogin(line string) (acceptedSSHLogin, bool) {
+	match := acceptedSSHLoginPattern.FindStringSubmatch(line)
+	if len(match) != 5 || net.ParseIP(match[3]) == nil {
+		return acceptedSSHLogin{}, false
+	}
+	port, err := strconv.Atoi(match[4])
+	if err != nil || port < 1 || port > 65535 {
+		return acceptedSSHLogin{}, false
+	}
+	method := strings.ToLower(strings.SplitN(match[1], "/", 2)[0])
+	switch method {
+	case "publickey", "password", "keyboard-interactive", "hostbased":
+	default:
+		return acceptedSSHLogin{}, false
+	}
+	return acceptedSSHLogin{user: match[2], remoteIP: match[3], remotePort: port, authMethod: method, occurredAt: time.Now().UTC()}, true
+}
+
+func reportAcceptedSSHLogin(event acceptedSSHLogin) error {
+	id := fmt.Sprintf("ssh-login-%d", event.occurredAt.UnixNano())
+	payload := v2.NewRequest(id, v2.MethodAgentSSHLogin, map[string]interface{}{
+		"user":        event.user,
+		"remote_ip":   event.remoteIP,
+		"remote_port": event.remotePort,
+		"auth_method": event.authMethod,
+		"occurred_at": event.occurredAt.Format(time.RFC3339Nano),
+	})
+	_, err := postV2Request(payload)
+	return err
+}
diff --git a/server/ssh_login_watch_test.go b/server/ssh_login_watch_test.go
new file mode 100644
